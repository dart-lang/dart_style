<<< 3.7
class TokenType {
  bool get isUserDefinableOperator =>
      identical(lexeme, "==") ||
      identical(lexeme, "~") ||
      identical(lexeme, "[]") ||
      identical(lexeme, "[]=") ||
      identical(lexeme, "*") ||
      identical(lexeme, "/") ||
      identical(lexeme, "%") ||
      identical(lexeme, "~/") ||
      identical(lexeme, "+") ||
      identical(lexeme, "-") ||
      identical(lexeme, "<<") ||
      identical(lexeme, ">>") ||
      identical(lexeme, ">=") ||
      identical(lexeme, ">") ||
      identical(lexeme, "<=") ||
      identical(lexeme, "<") ||
      identical(lexeme, "&") ||
      identical(lexeme, "^") ||
      identical(lexeme, "|");
}
